# MusicHub 环境变量样例
# 复制本文件为 .env 后按需修改（供本地直接跑后端 / pydantic-settings 读取）
# Docker Compose 不用本文件做端口映射；对外端口见 docker-compose.yml 的 ports。

# ===== 服务端口（容器内 / 本地 uvicorn）=====
PORT=5173

# ===== 路径 =====
# 音乐输出目录（容器内路径，宿主机通过 docker-compose volumes 映射）
MUSIC_DIR=/music

# 配置和数据库目录（容器内路径）
CONFIG_DIR=/config

# ===== 时区 =====
# 影响日志时间戳和定时任务触发时间
TZ=Asia/Shanghai

# ===== 日志级别 =====
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ===== HTTP 客户端代理（可选）=====
# 如果你的服务器访问平台接口需要走代理，在这里配置
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
